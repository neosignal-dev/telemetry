# Telegram бот для алертов
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# База данных PostgreSQL
POSTGRES_HOST=postgresql
POSTGRES_PORT=5432
POSTGRES_DB=telemetry
POSTGRES_USER=telemetry
POSTGRES_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=telemetry
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://telemetry:<password>@rabbitmq:5672/
QUEUE_NAME=telemetry.raw

# Generator Configuration
RATE_HZ=2
SAT_COUNT=5
ORBIT=LEO
REGIONS=RU

# Processor Configuration
PG_DSN=postgresql://telemetry:<password>@postgresql:5432/telemetry

# Yandex.Cloud (для Terraform)
YC_TOKEN=
YC_CLOUD_ID=
YC_FOLDER_ID=

# Kubernetes
KUBECONFIG_CONTENT=

# Мониторинг
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
VICTORIAMETRICS_RETENTION_PERIOD=30d

# SSH ключи
SSH_PUBLIC_KEY=
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
